# .env.example — Copier en .env et remplir les valeurs
# Ne JAMAIS commiter le .env réel

# ── Clés API dédiées monitoring (créer des clés séparées des clés prod) ──

# OpenAI — Admin key (scope api.usage.read requis)
# Créer sur : platform.openai.com > API Keys > "Create admin key"
OPENAI_API_KEY_MONITORING=sk-admin-...

# OpenRouter — clé standard
# Créer sur : openrouter.ai/settings/keys
OPENROUTER_API_KEY_MONITORING=sk-or-v1-...

# Anthropic — clé API standard (pas le token OAuth de session)
# Créer sur : console.anthropic.com > API Keys
ANTHROPIC_API_KEY_MONITORING=sk-ant-api03-...

# Google — clé API Gemini (si usage direct, pas via OpenRouter)
# Créer sur : console.cloud.google.com > APIs & Services > Credentials
GOOGLE_API_KEY=AIzaSy...

# ── Chemins internes (Docker) ── ne pas modifier sauf si vous changez les volumes

DB_PATH=/data/monitoring.db
OPENCLAW_LOGS_DIR=/openclaw-logs
OPENCLAW_SESSIONS_DIR=/openclaw-sessions
