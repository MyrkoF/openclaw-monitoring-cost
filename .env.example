# .env.example — Copier en .env et remplir les valeurs
# Ne JAMAIS commiter le .env réel

# ── Clés API dédiées monitoring (créer des clés séparées des clés prod) ──

# OpenAI — Admin key (scope api.usage.read requis)
# Créer sur : platform.openai.com > API Keys > "Create admin key"
OPENAI_API_KEY_MONITORING=sk-admin-...

# OpenRouter — clé standard
# Créer sur : openrouter.ai/settings/keys
OPENROUTER_API_KEY_MONITORING=sk-or-v1-...

# Anthropic — clé API standard (pour usage estimé depuis logs OpenClaw)
# Créer sur : console.anthropic.com > API Keys
ANTHROPIC_API_KEY_MONITORING=sk-ant-api03-...

# Anthropic Console billing (OPTIONNEL — pour crédits restants/consommés)
# Laisser vide = estimation logs uniquement
ANTHROPIC_CONSOLE_API_KEY=

# Google — clé API Gemini (si usage direct, pas via OpenRouter)
# Créer sur : console.cloud.google.com > APIs & Services > Credentials
GOOGLE_API_KEY=AIzaSy...

# ── Chemins internes (Docker) ── ne pas modifier sauf si vous changez les volumes ──

DB_PATH=/data/monitoring.db
OPENCLAW_LOGS_DIR=/openclaw-logs
OPENCLAW_SESSIONS_DIR=/openclaw-sessions

# ── Watchtower HTTP API (OPTIONNEL) ──
# URL du container Watchtower (host.docker.internal = hôte Docker depuis le container)
# Laisser WATCHTOWER_API_TOKEN vide = fallback automatique sur sidecar host-health.json
WATCHTOWER_API_URL=http://host.docker.internal:8080
WATCHTOWER_API_TOKEN=

# ── Google Cloud Billing (OPTIONNEL) ──
# Service account JSON key avec rôle billing.accounts.viewer
# Déposer à ~/google-sa-key.json et décommenter le volume dans docker-compose.yml
# GOOGLE_SA_KEY_PATH=/google-sa-key.json

# ── Sidecar hôte daily-health-check.py ──
# Chemin absolu du fichier JSON produit par le cron job sur le host
# Doit pointer vers un fichier dans le répertoire ./data/ (volume partagé)
# HEALTH_SIDECAR=/chemin/vers/openclaw-monitoring-cost/data/host-health.json
